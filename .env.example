# Reflective Lens — backend secrets. Copy to `.env` and fill in.
# `.env` is gitignored — never commit real keys.

# --- Required ---
ANTHROPIC_API_KEY=sk-ant-...          # Claude (reports, reflection, voice, etc.)
OPENAI_API_KEY=sk-...                 # Whisper transcription (voice notes/reflections)
LEARNING_CRON_SECRET=                 # shared secret for the run-learning sweep — `openssl rand -hex 24`
APP_URL=https://your-app.example      # your frontend URL (checkout redirects + PWA base)

# --- Optional: billing (Stripe) — only if you charge ---
STRIPE_SECRET_KEY=                    # sk_live_... / sk_test_...
STRIPE_WEBHOOK_SECRET=                # whsec_... (from the Stripe webhook you point at billing-webhook)
